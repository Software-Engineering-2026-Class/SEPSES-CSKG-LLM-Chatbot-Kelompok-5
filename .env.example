# ============================================================
# SEPSES CSKG LLM Chatbot - Environment Variables Template
# SALIN file ini menjadi .env dan ISI nilainya.
# JANGAN pernah commit file .env ke repository!
# ============================================================

# ---- OpenRouter Configuration (Unified LLM Access) ----
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# Model yang digunakan untuk chat/RAG pipeline
# Pilihan model yang tersedia di OpenRouter:
#   - openai/gpt-4o-mini          (GPT-4o mini dari OpenAI)
#   - openai/gpt-4o               (GPT-4o dari OpenAI)
#   - google/gemini-flash-latest  (Gemini Flash latest dari Google)
#   - google/gemini-1.5-pro       (Gemini 1.5 Pro dari Google)
#   - anthropic/claude-3.5-sonnet (Claude 3.5 Sonnet dari Anthropic)
#   - anthropic/claude-3-haiku    (Claude 3 Haiku dari Anthropic)
#   - meta-llama/llama-3-70b-instruct (Llama 3 70B dari Meta)
#   - mistralai/mistral-7b-instruct   (Mistral 7B)
#   - Dan 100+ model lainnya: https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---- SEPSES SPARQL Endpoint ----
# Endpoint publik (default). Jika tidak tersedia, gunakan Fuseki lokal.
SPARQL_ENDPOINT=https://w3id.org/sepses/sparql
SPARQL_TIMEOUT_SECONDS=30

# ---- Apache Jena Fuseki (Local Fallback) ----
FUSEKI_ENDPOINT=http://localhost:3030/sepses/sparql
FUSEKI_UPDATE_ENDPOINT=http://localhost:3030/sepses/update

# ---- ChromaDB Vector Store ----
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_LOGS=security_logs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Evaluation Settings ----
# Model yang digunakan sebagai judge untuk LLM-as-a-Judge
JUDGE_MODEL=gpt-4o-mini
EVAL_RESULTS_DIR=./evaluation/results

# ---- Application Settings ----
LOG_LEVEL=INFO
MAX_CONTEXT_TOKENS=4000
TOP_K_RETRIEVAL=5

